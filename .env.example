APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Send the session cookie only over HTTPS. Keep true in production (the app must
# sit behind TLS); set false only for plain-HTTP local development.
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
# Disk used for all media (images + video). Must be publicly servable: use `public`
# for local storage, or `s3` (set the AWS_* block below) for object storage. Video
# uploads use presigned direct-to-storage URLs, supported on both `public` and `s3`.
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# Must exceed the publish job's 900s timeout, or a slow large-video upload gets
# released to a second worker mid-run and double-posts. Raise both together if you
# raise the job timeout.
DB_QUEUE_RETRY_AFTER=1200

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# To store media on S3 (or S3-compatible: MinIO, R2, Spaces), set FILESYSTEM_DISK=s3
# and fill these in. Two bucket settings are required for direct video uploads:
#   1. CORS: allow PUT from your app origin, and expose the ETag header, e.g.
#      [{"AllowedMethods":["PUT"],"AllowedOrigins":["https://your-app.example"],
#        "AllowedHeaders":["*"],"ExposeHeaders":["ETag"]}]
#      Without this, browser uploads fail with an opaque CORS error.
#   2. Lifecycle: expire the `tmp/media/` prefix after ~1 day. This auto-cleans
#      abandoned uploads even if the scheduler is down, and is preferred over the
#      hourly `media:prune-uploads` command on S3.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

WORKSPACES_ENABLED=true
WORKSPACES_CAN_CREATE_WORKSPACE=true
WORKSPACE_INVITATION_TTL_DAYS=7

# Social login (Laravel Socialite)
SOCIALITE_ENABLED=false
# Comma-separated. Supported: google, x, linkedin. X and LinkedIn reuse the
# X_*/LINKEDIN_* credentials below (shared with connected accounts) — just also
# register the login callback (/auth/x/callback, /auth/linkedin/callback) in each
# provider's dev console. Note: X only returns an email if your app has email
# access enabled, which sign-up requires.
SOCIALITE_PROVIDERS=google

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback" # Redirect URI registered in Google Cloud console, e.g. https://your-app.test/auth/google/callback

# Connected accounts (workspace-owned posting accounts, distinct from social login above)
# OAuth credentials for X and LinkedIn. The connect button enables once the client id
# and secret are set. The callback URL is derived from the URL you actually serve the app
# on, so register that exact URL in each provider's developer app:
#   X:        <your-app-url>/accounts/callback/x        (e.g. http://127.0.0.1:8000/accounts/callback/x)
#   LinkedIn: <your-app-url>/accounts/callback/linkedin
# Bluesky uses app passwords, so it needs no credentials here.
X_CLIENT_ID=
X_CLIENT_SECRET=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ----------------------------------------------------------------------
# Docker / Octane (see compose.standalone.yaml, compose.all-in-one.yaml)
# ----------------------------------------------------------------------
# Octane runs the web tier via FrankenPHP worker mode.
OCTANE_SERVER=frankenphp

# Inertia SSR is off by default. Set to true to run the SSR process.
INERTIA_SSR_ENABLED=false
# INERTIA_SSR_URL=http://127.0.0.1:13714

# Image build/runtime knobs consumed by the compose files / serversideup image.
# APP_PORT=8080
# REGISTRY_IMAGE=laravel-template
# IMAGE_TAG=latest
# SERVERSIDEUP_PHP_VERSION=8.5-frankenphp-trixie
# POSTGRES_VERSION=17
# REDIS_VERSION=8

# To deploy on Postgres + Redis (with the matching compose profiles):
#   DB_CONNECTION=pgsql
#   DB_HOST=postgres
#   DB_DATABASE=laravel
#   DB_USERNAME=laravel
#   DB_PASSWORD=secret
#   CACHE_STORE=redis
#   QUEUE_CONNECTION=redis
#   REDIS_HOST=redis
