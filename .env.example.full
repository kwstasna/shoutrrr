# Full Shoutrrr environment reference.
# Copy only the values you need into .env. Keep secrets out of source control.

# ----------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------
APP_NAME=Shoutrrr
APP_ENV=local
APP_KEY=
APP_PREVIOUS_KEYS=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_PORT=8080
ASSET_URL=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

# Vite / browser-exposed values
VITE_APP_NAME="${APP_NAME}"
VITE_HMR_HOST=localhost
SKIP_WAYFINDER_GENERATE=false

# ----------------------------------------------------------------------
# Instance / workspace behavior
# ----------------------------------------------------------------------
SELF_HOSTED=true
INSTANCE_REGISTRATIONS_ENABLED=false
WORKSPACES_ENABLED=true
WORKSPACES_CAN_CREATE_WORKSPACE=true
WORKSPACE_INVITATION_TTL_DAYS=7

# ----------------------------------------------------------------------
# Authentication / Fortify / Passport
# ----------------------------------------------------------------------
AUTH_GUARD=web
AUTH_PASSWORD_BROKER=users
AUTH_MODEL=App\Models\User
AUTH_PASSWORD_RESET_TOKEN_TABLE=password_reset_tokens
AUTH_PASSWORD_TIMEOUT=10800
PASSKEYS_USER_HANDLE_SECRET=
PASSPORT_PRIVATE_KEY=
PASSPORT_PUBLIC_KEY=
PASSPORT_CONNECTION=

# ----------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------
DB_CONNECTION=sqlite
DB_URL=
DB_DATABASE=database/sqlite/database.sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_SOCKET=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_FOREIGN_KEYS=true
DB_SSLMODE=prefer
MYSQL_ATTR_SSL_CA=
DB_ENCRYPT=yes
DB_TRUST_SERVER_CERTIFICATE=false

# ----------------------------------------------------------------------
# Cache
# ----------------------------------------------------------------------
CACHE_STORE=database
CACHE_PREFIX=
DB_CACHE_CONNECTION=
DB_CACHE_TABLE=cache
DB_CACHE_LOCK_CONNECTION=
DB_CACHE_LOCK_TABLE=
CACHE_STORAGE_DISK=
CACHE_STORAGE_PATH=framework/cache/data

MEMCACHED_HOST=127.0.0.1
MEMCACHED_PORT=11211
MEMCACHED_USERNAME=
MEMCACHED_PASSWORD=
MEMCACHED_PERSISTENT_ID=

DYNAMODB_CACHE_TABLE=cache
DYNAMODB_ENDPOINT=

# ----------------------------------------------------------------------
# Redis
# ----------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_CLUSTER=redis
REDIS_PREFIX=
REDIS_PERSISTENT=false
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_MAX_RETRIES=3
REDIS_BACKOFF_ALGORITHM=decorrelated_jitter
REDIS_BACKOFF_BASE=100
REDIS_BACKOFF_CAP=1000
REDIS_CACHE_CONNECTION=cache
REDIS_CACHE_LOCK_CONNECTION=default

# ----------------------------------------------------------------------
# Queue
# ----------------------------------------------------------------------
QUEUE_CONNECTION=database
QUEUE_FAILED_DRIVER=database-uuids
DB_QUEUE_CONNECTION=
DB_QUEUE_TABLE=jobs
DB_QUEUE=default
DB_QUEUE_RETRY_AFTER=1200
BEANSTALKD_QUEUE_HOST=localhost
BEANSTALKD_QUEUE=default
BEANSTALKD_QUEUE_RETRY_AFTER=1200
SQS_PREFIX=https://sqs.us-east-1.amazonaws.com/your-account-id
SQS_QUEUE=default
SQS_SUFFIX=
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=1200

# ----------------------------------------------------------------------
# Session
# ----------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false
SESSION_CONNECTION=
SESSION_TABLE=sessions
SESSION_STORE=
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PARTITIONED_COOKIE=false

# ----------------------------------------------------------------------
# Filesystems / object storage
# ----------------------------------------------------------------------
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ----------------------------------------------------------------------
# Mail
# ----------------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=
MAIL_URL=
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_EHLO_DOMAIN=
MAIL_SENDMAIL_PATH="/usr/sbin/sendmail -bs -i"
MAIL_LOG_CHANNEL=
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"
MAIL_MARKDOWN_THEME=default
POSTMARK_API_KEY=
POSTMARK_MESSAGE_STREAM_ID=
RESEND_API_KEY=

# ----------------------------------------------------------------------
# Social login / connected accounts
# ----------------------------------------------------------------------
SOCIALITE_ENABLED=false
SOCIALITE_PROVIDERS=google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI="${APP_URL}/accounts/callback/x"
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI="${APP_URL}/accounts/callback/linkedin"
LINKEDIN_API_VERSION=202505


# ----------------------------------------------------------------------
# Notifications / external services
# ----------------------------------------------------------------------
SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=

# ----------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug
LOG_DEPRECATIONS_CHANNEL=null
LOG_DEPRECATIONS_TRACE=false
LOG_DAILY_DAYS=14
LOG_SLACK_WEBHOOK_URL=
LOG_SLACK_USERNAME="${APP_NAME}"
LOG_SLACK_EMOJI=:boom:
LOG_PAPERTRAIL_HANDLER=Monolog\Handler\SyslogUdpHandler
LOG_STDERR_FORMATTER=
LOG_SYSLOG_FACILITY=8
PAPERTRAIL_URL=
PAPERTRAIL_PORT=

# ----------------------------------------------------------------------
# Inertia SSR / Octane / Docker image knobs
# ----------------------------------------------------------------------
INERTIA_SSR_ENABLED=false
INERTIA_SSR_URL=http://127.0.0.1:13714
OCTANE_SERVER=frankenphp
OCTANE_HTTPS=false
QUEUE_WORKER_ENABLED=true
SCHEDULER_ENABLED=true
SSL_MODE=off
PHP_OPCACHE_ENABLE=1
AUTORUN_ENABLED=true
AUTORUN_LARAVEL_CONFIG_CACHE=true
AUTORUN_LARAVEL_EVENT_CACHE=true
AUTORUN_LARAVEL_ROUTE_CACHE=true
AUTORUN_LARAVEL_VIEW_CACHE=true
AUTORUN_LARAVEL_STORAGE_LINK=true
POSTGRES_VERSION=17
POSTGRES_DB=laravel

# ----------------------------------------------------------------------
# Metrics / posts
# ----------------------------------------------------------------------
METRICS_ENABLED=true
ENGAGEMENT_ENABLED=true
ENGAGEMENT_WINDOW_DAYS=7
POSTS_MISSED_AFTER_MINUTES=2880
